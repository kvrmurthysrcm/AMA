{
  "info": {
    "name": "AMA Agent Service",
    "_postman_id": "ama-agent-service-collection",
    "description": "Postman collection for testing the AMA Agent service. Assumes Agent runs on localhost:8083, Tools on 8082, Analytics on 8081.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8083"
    },
    {
      "key": "tenantId",
      "value": "1001"
    },
    {
      "key": "accountId",
      "value": "1001"
    },
    {
      "key": "marketplaceCode",
      "value": "IN"
    }
  ],
  "item": [
    {
      "name": "Top Products - Last Month",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "description": "Basic happy-path query. Agent should discover tools, choose get_top_products or similar, call Tools service, and return summary + data + chartType.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Which products sold best in the last month?\",\n  \"tenantId\": 1001,\n  \"accountIds\": [\n    1001\n  ],\n  \"marketplaceCodes\": [\n    \"IN\"\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/agent/v1/query",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "agent",
            "v1",
            "query"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Sales Trend - Last 30 Days",
